{
  "manifest_version": 3,
  "name": "SmartSpend",
  "version": "1.0.0",
  "description": "AI-powered purchase advisor. Get a BUY, WAIT, or AVOID signal on any checkout page.",

  "permissions": ["storage"],
  "host_permissions": ["<all_urls>", "http://localhost:8000/*"],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["theme.js", "content.js"],
      "run_at": "document_idle"
    }
  ],

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "SmartSpend"
  },

  "web_accessible_resources": [
    {
      "resources": ["wizard.html", "dashboard.html", "components.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
